# ─────────────────────────────────────────────
# OneAds — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# ── Servidor ──────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=troque_por_uma_chave_secreta_forte

# ── Google (Drive + Google Ads) ───────────────
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Meta Ads (Facebook / Instagram) ──────────
# Crie em: https://developers.facebook.com/apps/
META_APP_ID=seu_meta_app_id
META_APP_SECRET=seu_meta_app_secret
META_REDIRECT_URI=http://localhost:8000/auth/meta/callback

# ── TikTok Ads ────────────────────────────────
# Crie em: https://ads.tiktok.com/marketing_api/apps/
TIKTOK_APP_ID=seu_tiktok_app_id
TIKTOK_APP_SECRET=seu_tiktok_app_secret
TIKTOK_REDIRECT_URI=http://localhost:8000/auth/tiktok/callback

# ── Hotmart ───────────────────────────────────
# Gere em: https://developers.hotmart.com/
HOTMART_CLIENT_ID=seu_hotmart_client_id
HOTMART_CLIENT_SECRET=seu_hotmart_client_secret
HOTMART_REDIRECT_URI=http://localhost:8000/auth/hotmart/callback

# ── Google Drive (pasta padrão de dados) ──────
DRIVE_ROOT_FOLDER_NAME=OneAds Data
